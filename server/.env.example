# ─────────────────────────────────────────────────────────────────────────────
# AI Moodify — Server Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to Git — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Hume AI API key — used by the Python pipeline to call the Hume Streaming API
# Obtain from: https://platform.hume.ai/settings/keys
HUME_API_KEY=your_hume_api_key_here

# YouTube Data API v3 key — used for dynamic Bollywood song search
# Obtain from: https://console.cloud.google.com/
YOUTUBE_API_KEY=your_youtube_api_key_here
